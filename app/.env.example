# =============================================================================
# BIM Estimator - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set for the app to function.
# Variables marked [OPTIONAL] have sensible defaults in code.
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# [OPTIONAL] Port the server listens on (default: 5000)
PORT=5000

# [OPTIONAL] Node environment: "development" | "production" (default: development)
NODE_ENV=development

# [OPTIONAL] Public base URL of the application, used for Stripe redirect URLs
# Default: http://localhost:5000
APP_BASE_URL=http://localhost:5000

# [OPTIONAL] App version string reported by health-check endpoint (default: "unknown")
APP_VERSION=0.1.0

# [OPTIONAL] Allowed CORS origin. Set to a specific origin in production.
# In development defaults to http://localhost:5000; set to "*" to allow all.
CLIENT_ORIGIN=http://localhost:5000

# [OPTIONAL] Set to "true" to run CI-specific config in Playwright, etc.
# CI=true

# [OPTIONAL] Replit environment identifier (used by Vite config for HMR)
# REPL_ID=


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/bim_estimator

# [OPTIONAL] PostgreSQL host — checked by diagnostics endpoint
# PGHOST=localhost


# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------

# [REQUIRED in production] Secret used to sign JWTs.
# In development a random secret is generated if not set; in production the app
# will throw if this is missing.
JWT_SECRET=your-jwt-secret-here

# [OPTIONAL] Secret used to sign refresh tokens (default: JWT_SECRET + "_refresh")
# REFRESH_SECRET=your-refresh-secret-here

# [OPTIONAL] Bypass authentication in development. Set to "on" to enable.
# Only works when NODE_ENV=development. (default: "off")
# DEV_AUTH_BYPASS=off


# -----------------------------------------------------------------------------
# AI / Anthropic (Claude)
# -----------------------------------------------------------------------------

# [REQUIRED] Anthropic API key for all AI-powered features (BIM generation,
# document analysis, cost estimation, similarity scoring, etc.)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# [OPTIONAL] General Claude API call timeout in milliseconds (default: 300000 = 5 min)
# CLAUDE_TIMEOUT_MS=300000

# [OPTIONAL] Maximum prompt tokens sent per Claude request (default: 200000)
# CLAUDE_MAX_PROMPT_TOKENS=200000

# [OPTIONAL] Token headroom reserved for Claude response (default: 20000)
# CLAUDE_HEADROOM_TOKENS=20000

# [OPTIONAL] Tokens per batch when splitting large prompts (default: 15000)
# CLAUDE_PER_BATCH_TOKENS=15000

# [OPTIONAL] Similarity-analysis specific Claude timeout (default: 300000 = 5 min)
# CLAUDE_SIM_TIMEOUT_MS=300000

# [OPTIONAL] Retry attempts for similarity Claude calls (default: 4)
# CLAUDE_SIM_RETRY_ATTEMPTS=4

# [OPTIONAL] Base delay in ms for similarity retries (default: 700)
# CLAUDE_SIM_RETRY_BASE_MS=700

# [OPTIONAL] Max delay in ms for similarity retries (default: 12000)
# CLAUDE_SIM_RETRY_MAX_MS=12000


# -----------------------------------------------------------------------------
# Stripe (Payments & Subscriptions)
# -----------------------------------------------------------------------------

# [REQUIRED for billing] Stripe secret API key
STRIPE_SECRET_KEY=sk_test_your-stripe-key-here

# [REQUIRED for billing] Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# [OPTIONAL] Number of free trial days (default: 14)
# TRIAL_DAYS=14

# -- Stripe Price IDs: BYOL (Bring Your Own License) plans -------------------

# [OPTIONAL] Starter BYOL plan price IDs
# STRIPE_PRICE_STARTER_BYOL_MONTHLY=price_xxx
# STRIPE_PRICE_STARTER_BYOL_ANNUAL=price_xxx

# [OPTIONAL] Pro BYOL plan price IDs
# STRIPE_PRICE_PRO_BYOL_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_BYOL_ANNUAL=price_xxx

# [OPTIONAL] Enterprise BYOL plan price IDs
# STRIPE_PRICE_ENTERPRISE_BYOL_MONTHLY=price_xxx
# STRIPE_PRICE_ENTERPRISE_BYOL_ANNUAL=price_xxx

# -- Stripe Price IDs: Included-AI plans -------------------------------------

# [OPTIONAL] Starter Included plan price IDs
# STRIPE_PRICE_STARTER_INCLUDED_MONTHLY=price_xxx
# STRIPE_PRICE_STARTER_INCLUDED_ANNUAL=price_xxx

# [OPTIONAL] Pro Included plan price IDs
# STRIPE_PRICE_PRO_INCLUDED_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_INCLUDED_ANNUAL=price_xxx

# [OPTIONAL] Enterprise Included plan price IDs
# STRIPE_PRICE_ENTERPRISE_INCLUDED_MONTHLY=price_xxx
# STRIPE_PRICE_ENTERPRISE_INCLUDED_ANNUAL=price_xxx

# [OPTIONAL] Single-project one-time purchase price ID
# STRIPE_PRICE_SINGLE_PROJECT=price_xxx


# -----------------------------------------------------------------------------
# Admin API
# -----------------------------------------------------------------------------

# [OPTIONAL] API key for admin/service-to-service endpoints (cost-rate
# management, etc.). If unset, admin endpoints fall back to session auth only.
# ADMIN_API_KEY=your-admin-api-key-here


# -----------------------------------------------------------------------------
# RSMeans Integration
# -----------------------------------------------------------------------------

# [OPTIONAL] RSMeans / Gordian Data API key (default: empty string)
# RSMEANS_API_KEY=your-rsmeans-key

# [OPTIONAL] RSMeans API base URL (default: https://dataapi-sb.gordian.com/v1)
# RSMEANS_API_URL=https://dataapi-sb.gordian.com/v1


# -----------------------------------------------------------------------------
# File Storage & Uploads
# -----------------------------------------------------------------------------

# [OPTIONAL] Directory for storing uploaded/processed files (default: ./uploads)
# LOCAL_STORAGE_DIR=./uploads

# [OPTIONAL] Temporary upload directory (default: ./tmp_uploads)
# UPLOAD_TMP_DIR=./tmp_uploads

# [OPTIONAL] Final upload directory (default: ./uploads)
# UPLOAD_FINAL_DIR=./uploads

# [OPTIONAL] Maximum upload file size in MB (default: 200)
# UPLOAD_MAX_MB=200


# -----------------------------------------------------------------------------
# BIM Generation Tuning
# -----------------------------------------------------------------------------

# [OPTIONAL] Default Level of Detail: "summary" | "detailed" | "comprehensive"
# (default: "detailed")
# DEFAULT_LOD=detailed

# [OPTIONAL] Element positioning mode: "auto" | "forcePerimeter" | "preferClaude"
# (default: "auto")
# POSITIONING_MODE=auto

# [OPTIONAL] Clamp outlier element positions beyond this distance in meters.
# Unset = no clamping.
# CALIB_CLAMP_M=

# [OPTIONAL] Default floor height in meters for storey inference.
# If unset, uses building-specific heuristics.
# FLOOR_HEIGHT_M=

# [OPTIONAL] Fallback number of floors when height data is unavailable (default: 1)
# FLOORS_GUESS=1

# [OPTIONAL] Ratio threshold for swapping width/depth axes on elements (default: 1.5)
# DIM_AXIS_SWAP_RATIO=1.5


# -----------------------------------------------------------------------------
# LOD Balancer / Assembler Tuning
# -----------------------------------------------------------------------------

# [OPTIONAL] Minimum count of structural+architectural elements (default: 50)
# MIN_BASE_STRUCT_ARCH_COUNT=50

# [OPTIONAL] Minimum fraction of structural+architectural elements (default: 0.20)
# MIN_BASE_STRUCT_ARCH_FRACTION=0.20

# [OPTIONAL] Minimum structural fraction in LOD balancing (default: 0.25)
# LOD_MIN_STRUCT_FRAC=0.25

# [OPTIONAL] Target architectural fraction in LOD balancing (default: 0.30)
# LOD_TARG_ARCH_FRAC=0.30

# [OPTIONAL] Maximum grid/MEP fraction in LOD balancing (default: 0.45)
# LOD_MAX_GRID_FRAC=0.45


# -----------------------------------------------------------------------------
# LOD Element Spacing & Density
# -----------------------------------------------------------------------------

# [OPTIONAL] Override spacing (meters) for lights, sprinklers, receptacles
# LOD_LIGHT_SPACING=
# LOD_SPRINKLER_SPACING=
# LOD_RECEPTACLE_SPACING=

# [OPTIONAL] Override density (count per sq meter) for lights, sprinklers, receptacles
# LOD_LIGHT_DENSITY=
# LOD_SPRINKLER_DENSITY=
# LOD_RECEPTACLE_DENSITY=


# -----------------------------------------------------------------------------
# Cost Estimation
# -----------------------------------------------------------------------------

# [OPTIONAL] Default measurement units: "metric" | "imperial" (default: "metric")
# COST_UNITS=metric

# [OPTIONAL] Cost profile identifier (default: empty)
# COST_PROFILE=

# [OPTIONAL] JSON string of custom cost rates. Parsed at runtime.
# COST_RATES_JSON=


# -----------------------------------------------------------------------------
# Document Similarity & Eviction
# -----------------------------------------------------------------------------

# [OPTIONAL] Max concurrent similarity comparisons (default: 3)
# SIMILARITY_CONCURRENCY=3

# [OPTIONAL] Behavior on similarity failure: "skip" | "error" (default: "skip")
# SIMILARITY_ON_FAIL=skip

# [OPTIONAL] Neutral similarity score returned on failure (default: 0.5)
# SIMILARITY_NEUTRAL_SCORE=0.5

# [OPTIONAL] Interval in ms between similarity eviction runs (default: 21600000 = 6h)
# SIM_EVICT_INTERVAL_MS=21600000

# [OPTIONAL] Max age in days for similarity records before eviction (default: 90)
# SIM_EVICT_MAX_AGE_DAYS=90

# [OPTIONAL] Max total similarity rows to keep (default: 100000)
# SIM_EVICT_MAX_ROWS=100000

# [OPTIONAL] Max similarity pairs per project; 0 = disabled (default: 0)
# SIM_EVICT_PROJECT_MAX_PAIRS=0

# [OPTIONAL] Eviction mode per project: "score" | "recent" (default: "score")
# SIM_EVICT_PROJECT_MODE=score

# [OPTIONAL] Comma-separated project IDs to apply per-project eviction to
# SIM_EVICT_PROJECT_IDS=


# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# [OPTIONAL] Enable drawing analyzer service: "on" | "off" (default: "on")
# ENABLE_DRAWING_ANALYZER=on

# [OPTIONAL] Enable raster glyph detection for symbol recognition: "on" | "off"
# (default: "off")
# ENABLE_RASTER_GLYPH=off

# [OPTIONAL] Force calibration of BIM element positions: "on" | "off" (default: "off")
# CALIBRATE_FORCE=off

# [OPTIONAL] Enable site/drawing symbol detection: "on" | "off" (default: "off")
# SITE_SYMBOL_DETECT=off

# [OPTIONAL] Block deprecated API paths: "true" | "false" (default: not set = allowed)
# BLOCK_DEPRECATED_PATHS=false

# [OPTIONAL] Force background processor in development (normally production-only)
# FORCE_BACKGROUND_PROCESSOR=false

# [OPTIONAL] Force enhanced processing pipeline — checked by diagnostics only
# FORCE_ENHANCED_PIPELINE=

# [OPTIONAL] Enable postprocessing on serve — checked by diagnostics only
# POSTPROCESS_ON_SERVE=


# -----------------------------------------------------------------------------
# Raster / Image Processing
# -----------------------------------------------------------------------------

# [OPTIONAL] Max number of pages to process for raster glyph detection (default: 30)
# RASTER_MAX_PAGES=30

# [OPTIONAL] Stride (step size) for raster scanning (default: 8)
# RASTER_STRIDE=8


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# [OPTIONAL] Log level: "DEBUG" | "INFO" | "WARN" | "ERROR" (default: "INFO")
# LOG_LEVEL=INFO
