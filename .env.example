# EstimatorPro Environment Configuration

# Enhanced Pipeline Controls
DEFAULT_LOD=detailed
FORCE_ENHANCED_PIPELINE=on
CALIBRATE_FORCE=on
POSTPROCESS_ON_SERVE=on
SITE_SYMBOL_DETECT=on

# Balanced LOD Controls (prevent MEP over-allocation)
LOD_MIN_STRUCT_FRAC=0.25
LOD_TARG_ARCH_FRAC=0.30
LOD_MAX_GRID_FRAC=0.45

# MEP Density Controls
LOD_LIGHT_DENSITY=1
LOD_SPRINKLER_DENSITY=1
LOD_RECEPTACLE_DENSITY=1

# MEP Spacing Controls (meters)
LOD_LIGHT_SPACING=9
LOD_SPRINKLER_SPACING=3.6
LOD_RECEPTACLE_SPACING=5

# Database
DATABASE_URL=your_database_url_here

# Other secrets managed by Replit
